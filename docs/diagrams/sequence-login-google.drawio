    <!-- ===== OAuth2 Authorization Code Flow ===== -->
    <!-- Client -> AuthController directly -->
    <mxCell id="m1" value="GET /api/auth/google/login" style="html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="165" as="sourcePoint"/><mxPoint x="285" y="165" as="targetPoint"/></mxGeometry>
    </mxCell>
    <!-- AuthController triggers OAuth2 redirect -->
    <mxCell id="m3" value="response.sendRedirect(&quot;/oauth2/authorization/google&quot;)" style="html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="285" y="195" as="sourcePoint"/><mxPoint x="515" y="195" as="targetPoint"/></mxGeometry>
    </mxCell>
    <mxCell id="m4" value="302 Redirect → Google Consent Screen URL" style="html=1;endArrow=open;endFill=0;fontSize=11;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="515" y="225" as="sourcePoint"/><mxPoint x="90" y="225" as="targetPoint"/></mxGeometry>
    </mxCell>

    <mxCell id="m5" value="User grants Google consent" style="html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="265" as="sourcePoint"/><mxPoint x="750" y="265" as="targetPoint"/></mxGeometry>
    </mxCell>
    <!-- Google redirects back with auth code directly to backend -->
    <mxCell id="m6" value="GET /login/oauth2/code/google?code=AUTH_CODE" style="html=1;endArrow=open;endFill=0;fontSize=11;dashed=1;" edge="1" parent="1">
